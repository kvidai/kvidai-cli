{
  "name": "@kvidai/cli",
  "version": "0.7.0",
  "description": "Agent-first CLI for kvidai — generate, manage, and stream AI videos",
  "type": "module",
  "bin": {
    "kvidai": "./dist/kvidai",
    "kvd": "./dist/kvidai"
  },
  "scripts": {
    "build": "bun run scripts/gen-version.ts && bun build --compile --minify --bytecode src/index.ts --outfile dist/kvidai",
    "dev": "bun run src/index.ts",
    "typecheck": "tsc --noEmit",
    "format": "biome format --write",
    "lint": "biome lint --write",
    "check": "biome check src",
    "skills:index": "bun run scripts/build-skills-index.ts",
    "skills:index:check": "bun run scripts/build-skills-index.ts --check",
    "prepare": "husky"
  },
  "keywords": [
    "kvidai",
    "ai",
    "cli",
    "video",
    "generation",
    "agent"
  ],
  "dependencies": {
    "chalk": "^5.6.2",
    "citty": "^0.2.2",
    "dotenv": "^17.4.2",
    "ora": "^9.4.0",
    "posthog-node": "^5.38.1",
    "prompts": "^2.4.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.7",
    "bun-types": "^1.3.10",
    "husky": "^9.1.7",
    "typescript": "^5.9.3"
  }
}
